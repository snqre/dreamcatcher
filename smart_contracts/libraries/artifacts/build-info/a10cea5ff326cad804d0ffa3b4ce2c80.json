			"smart_contracts/libraries/Math.sol": {
				"content": "// SPDX-License-Identifier: MIT\r\npragma solidity ^0.8.0;\r\n\r\nlibrary Math {\r\n    // is the value positive or negative\r\n    function checkSkew(uint256 _value) internal returns (bool) {\r\n        if (_value > 0) {\r\n            return true;\r\n        }\r\n        else if (_value < 0) {\r\n            return false;\r\n        }\r\n    }\r\n}\r\n"
			}
		},
