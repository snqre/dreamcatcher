			"smart_contracts/libraries/Meta.sol": {
				"content": "// SPDX-License-Identifier: MIT\npragma solidity ^0.8.0;\n\nlibrary Meta {\n    struct Properties {\n        string name;\n        string symbol;\n        uint256 decimals;\n        uint256 maxSupply;\n        uint256 totalSupply;\n        uint256 totalVested;\n        uint256 totalStaked;\n    }\n\n    struct Database {\n        mapping(address => uint256) balance;\n        mapping(address => uint256) vested;\n        mapping(address => uint256) staked;\n        mapping(address => uint256) vote;\n        mapping(address => mapping(address => uint256)) allowed;\n        // votes can be delegated to other accounts\n        mapping(address => mapping(address => uint256)) delegatedVote;\n    }\n\n    struct Quorum {\n        uint256 proposalCount;\n        uint256 requiredQuorum;\n    }\n\n    struct Settings {\n        uint256 minBalanceForMembership;\n        uint256 minStakeForMembership;\n        uint256 minBalanceForSyndicate;\n        uint256 minStakeForSyndicate;\n        \n    }\n}\n"
			}
		},
